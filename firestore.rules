rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "mdks9959@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'email', 'role', 'points', 'createdAt']) &&
             data.uid is string &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.email is string &&
             data.role in ['student', 'admin'] &&
             data.points is number && data.points >= 0 &&
             data.createdAt is string;
    }

    function isValidContribution(data) {
      return data.keys().hasAll(['id', 'experimentId', 'userId', 'username', 'content', 'type', 'upvotes', 'createdAt']) &&
             data.id is string &&
             data.experimentId is string &&
             data.userId is string &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             (!('fileUrl' in data) || (data.fileUrl is string && data.fileUrl.size() < 2000)) &&
             data.type in ['note', 'solution', 'code', 'diagram', 'comment'] &&
             data.upvotes is number && data.upvotes >= 0 &&
             data.createdAt is string;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'student' || isAdmin()) &&
                    request.resource.data.points == 0;
      allow update: if isAuthenticated() && isValidUser(request.resource.data) &&
                    (
                      (isOwner(userId) && request.resource.data.role == resource.data.role && 
                       request.resource.data.points == resource.data.points) || 
                      isAdmin() ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points']) && 
                       request.resource.data.points > resource.data.points)
                    );
    }

    match /labs/{labId} {
      allow read: if true;
      allow write: if true;
    }

    match /experiments/{experimentId} {
      allow read: if true;
      allow write: if true;
    }

    match /contributions/{contributionId} {
      allow read: if true;
      allow create: if isValidContribution(request.resource.data) &&
                    request.resource.data.upvotes == 0;
      allow update: if isValidContribution(request.resource.data) &&
                    (
                      (isOwner(resource.data.userId) && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content', 'fileUrl', 'type']) &&
                       request.resource.data.upvotes == resource.data.upvotes) ||
                      isAdmin() ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes']) &&
                       math.abs(request.resource.data.upvotes - resource.data.upvotes) == 1)
                    );
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /upvotes/{upvoteId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    request.resource.data.keys().hasAll(['userId', 'contributionId', 'createdAt']) &&
                    request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
